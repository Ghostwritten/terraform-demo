# Example 1: import an existing resource group into Terraform management.
#
# 1. Keep create_resource_group = true so the target address exists
# 2. Set resource_group_name to match the real resource group name
# 3. Copy this file to imports.tf at the repository root
# 4. Run terraform plan/apply with your dev tfvars

import {
  to = alicloud_resource_manager_resource_group.this[0]
  id = "rg-xxxxxxxx"
}

